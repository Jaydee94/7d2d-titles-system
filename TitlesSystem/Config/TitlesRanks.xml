<?xml version="1.0" encoding="UTF-8"?>
<!--
    TitlesRanks.xml - Rank and Title Definitions for the 7D2D Titles System
    
    Each <Rank> requires the following attributes:
      kills       - Minimum zombie kills required to achieve this rank
      title       - The full display title shown in rank-up announcements
      shortTitle  - Abbreviated title displayed above the player model in-game
    
    Ranks MUST be ordered by ascending kill count.
    The first rank (kills="0") is the default starting rank.
-->
<TitlesConfig>

    <Settings>
        <!-- Display the short rank title in brackets above the player's name in-game -->
        <ShowRankInName value="true"/>

        <!-- Broadcast a global server announcement when a player ranks up -->
        <AnnounceRankUp value="true"/>

        <!-- Save player rank data to disk every N minutes (0 = only on disconnect/event) -->
        <AutoSaveIntervalMinutes value="5"/>
    </Settings>

    <Ranks>
        <!-- Starter rank - everyone begins here -->
        <Rank kills="0"      title="Freshly Irradiated Civilian"  shortTitle="Civilian"/>

        <!-- Getting started -->
        <Rank kills="10"     title="Dumpster Diver of Doom"       shortTitle="Diver"/>
        <Rank kills="25"     title="Rusty Nail Enthusiast"        shortTitle="Rusty"/>
        <Rank kills="50"     title="Can Opener Connoisseur"       shortTitle="CanOpener"/>

        <!-- Intermediate -->
        <Rank kills="100"    title="Wandering Wastelander"        shortTitle="Wanderer"/>
        <Rank kills="200"    title="Scavenger of the Fallen"      shortTitle="Scavenger"/>
        <Rank kills="350"    title="Honorary Raider"              shortTitle="Raider"/>

        <!-- Advanced -->
        <Rank kills="500"    title="Vault Door Kickboxer"         shortTitle="VaultKicker"/>
        <Rank kills="750"    title="Mutant Whisperer"             shortTitle="Whisperer"/>
        <Rank kills="1000"   title="The Last Shotgun Shell"       shortTitle="LastShell"/>

        <!-- Expert -->
        <Rank kills="1500"   title="Duke of the Dead Lands"       shortTitle="Duke"/>
        <Rank kills="2500"   title="Horde Night Headliner"        shortTitle="Headliner"/>
        <Rank kills="4000"   title="Ambassador of Annihilation"   shortTitle="Ambassador"/>

        <!-- Legend -->
        <Rank kills="6000"   title="Warlord of the Wasteland"     shortTitle="Warlord"/>
        <Rank kills="9000"   title="Shepherd of the Apocalypse"   shortTitle="Shepherd"/>
        <Rank kills="15000"  title="The Undying Ghoul Hunter"     shortTitle="Undying"/>

        <!-- Mythical -->
        <Rank kills="25000"  title="Harbinger of the Final Horde" shortTitle="Harbinger"/>
        <Rank kills="50000"  title="The Rad-Scorpion King"        shortTitle="RadKing"/>
        <Rank kills="100000" title="Chosen One of the Wasteland"  shortTitle="ChosenOne"/>
    </Ranks>

</TitlesConfig>
